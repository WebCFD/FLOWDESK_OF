FoamFile
{
    version   2.0;
    format    ascii;
    class     dictionary;
    location  "system";
    object    meshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

surfaceFile "$STL_FILENAME";

// CRITICAL: Enforce geometry constraint - cfMesh MUST respect the STL surface
enforceGeometry 1;

// CRITICAL: Keep cells intersecting boundary to mesh INTERIOR (not exterior)
// This is essential for HVAC internal flow simulations
keepCellsIntersectingBoundary 1;

// Check for glued mesh to fix gaps
checkForGluedMesh 1;

maxCellSize $MAX_CELL_SIZE;

// Uniform mesh - no boundary layer refinement for testing
// Using fixed cell size throughout the domain
boundaryCellSize $MAX_CELL_SIZE;

// Minimum cell size allowed
minCellSize $MAX_CELL_SIZE;

// Reproject surface points for better geometry capture
renameBoundary
{
    defaultName        walls;
    defaultType        wall;
}

// Quality settings for mesh optimization
meshQualitySettings
{
    // Maximum non-orthogonality angle (degrees)
    // Lower is better, 65 is acceptable for CFD
    maxNonOrthogonality 65;
    
    // Maximum boundary skewness
    maxBoundarySkewness 20;
    
    // Maximum internal skewness
    maxInternalSkewness 4;
    
    // Minimum cell volume (cubic meters)
    minCellVolume 1e-13;
    
    // Minimum face area
    minFaceArea 1e-13;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
